lazy-100 cartridge
version 1
title Lazy Bird
author Lazy_V
__lua__
-- Lazy Bird - a flappy homage cart for Lazy-100. Original art; gameplay constants
-- follow the open-source FlapPyBird feel at 30 fps, adapted to a 320x240 landscape:
--   original (per frame @30fps): gravity +1, flap -9, max fall +10, pipe speed -4
--   landscape-adapted: pipe gap 88 (vs 100 on a 400px-tall field), pipe spacing 172
-- Tap \5 (Z) to flap. Generated into carts/lazybird.lz100 by scripts/lazybird/gen.py.

-- sheet layout (see gen.py): bird 34x24 @ (0,0)(40,0)(80,0); pipe cap 52x13 @ (0,32);
-- pipe body 52x8 @ (0,48); ground 32x24 @ (64,32); skyline 64x28 @ (128,32);
-- digits 14x20 @ (i*16,96); medals 22x22 @ (0,128)(24,128)

GRAV=1 FLAP=-9 MAXFALL=10 PIPEVX=4
GAP=88 SPACING=172 PIPEW=52
GROUNDY=216 BIRDX=64 BIRDW=34 BIRDH=24
SKY=132 -- palette index of the sky (see gen.py legend)

function _init()
  cartdata("lazybird")  -- persistent save: slot 0 = best score (saves/, IDBFS on web)
  best=dget(0)
  to_ready()
end

function to_ready()
  state="ready"
  by=104 bvy=0 tick=0 frame=0
  pipes={} score=0
  scroll=0 -- shared world scroll for ground/skyline parallax
  flash=0
end

function start_play()
  state="play"
  bvy=FLAP sfx(0)
  -- first pipe enters from the right edge after a beat
  add_pipe(340)
end

function add_pipe(x)
  -- gap top: keep 26px off the ceiling and 34px above the ground
  local lo=26
  local hi=GROUNDY-GAP-34
  pipes[#pipes+1]={x=x, gy=lo+flr(rnd(hi-lo+1)), passed=false}
end

function _update()
  tick=tick+1
  -- hit-flash always drains, whatever the state: a ground-level death can jump
  -- dead->over within a frame or two, and the flash must never outlive it
  if flash>0 then flash=flash-1 end

  if state=="ready" then
    by=104+sin(tick/30)*5
    scroll=scroll+1
    if tick%6==0 then frame=(frame+1)%3 end
    if btnp(4) then start_play() end
    return
  end

  if state=="play" then
    if btnp(4) then bvy=FLAP sfx(0) end
    bvy=mid(-99,bvy+GRAV,MAXFALL)
    by=by+bvy
    scroll=scroll+PIPEVX
    if tick%3==0 then frame=(frame+1)%3 end

    -- pipes march left; spawn to keep them SPACING apart
    for _,p in ipairs(pipes) do p.x=p.x-PIPEVX end
    if pipes[#pipes] and pipes[#pipes].x<320-SPACING+PIPEW then
      add_pipe(pipes[#pipes].x+SPACING)
    end
    if pipes[1] and pipes[1].x<-PIPEW then
      for i=1,#pipes-1 do pipes[i]=pipes[i+1] end
      pipes[#pipes]=nil
    end

    -- scoring: the pipe's trailing edge passes the bird
    for _,p in ipairs(pipes) do
      if not p.passed and p.x+PIPEW<BIRDX then
        p.passed=true score=score+1 sfx(1)
        if score>best then best=score dset(0,best) end -- dset writes through to disk
      end
    end

    -- collision: shrunken bird box vs pipes / ground / ceiling
    local bx0,by0=BIRDX+2,by+2
    local bx1,by1=BIRDX+BIRDW-3,by+BIRDH-3
    local dead=false
    if by1>=GROUNDY then dead=true end
    if by0<0 then by=0 bvy=0 end
    for _,p in ipairs(pipes) do
      if bx1>p.x and bx0<p.x+PIPEW then
        if by0<p.gy or by1>p.gy+GAP then dead=true end
      end
    end
    if dead then
      state="dead" flash=3 bvy=0
      sfx(2) sfx(3,1)
    end
    return
  end

  if state=="dead" then
    -- fall to the ground, then show the results panel
    if flash>0 then flash=flash-1 end
    bvy=mid(-99,bvy+GRAV,MAXFALL+4)
    by=by+bvy
    if by+BIRDH-3>=GROUNDY then
      by=GROUNDY-BIRDH+3
      state="over" sfx(4)
    end
    return
  end

  if state=="over" then
    if btnp(4) then to_ready() end
    return
  end
end

function draw_pipe(p)
  -- body tiles below/above the gap, caps facing the opening (top pipe flipped)
  local x=p.x
  for y=p.gy+GAP+13,GROUNDY-1,8 do sspr(0,48,52,8,x,y) end
  sspr(0,32,52,13,x,p.gy+GAP)
  for y=p.gy-13-8,-8,-8 do sspr(0,48,52,8,x,y) end
  sspr(0,32,52,13,x,p.gy-13,52,13,false,true)
end

function draw_num(n,cx,y)
  local s=string.format("%d",n) -- dget() returns a float ("5.0" would draw as 5 _ 0)
  local w=#s*15-1
  local x=cx-flr(w/2)
  for i=1,#s do
    local d=s:byte(i)-48
    sspr(d*16,96,14,20,x,y)
    x=x+15
  end
end

function draw_bird()
  sspr(frame*40,0,34,24,BIRDX,flr(by))
end

function _draw()
  cls(SKY)

  -- far skyline: slow parallax band sitting on the ground line
  local sx=-(flr(scroll/3)%64)
  for x=sx-64,320,64 do sspr(128,32,64,28,x,GROUNDY-28) end

  for _,p in ipairs(pipes) do draw_pipe(p) end

  -- ground: scrolls at pipe speed
  local gx=-(scroll%32)
  for x=gx-32,320,32 do sspr(64,32,32,24,x,GROUNDY) end

  draw_bird()

  if state=="ready" then
    local ty=60
    print("LAZY BIRD",137,ty-1,16) print("LAZY BIRD",136,ty,10)
    print("press \5 to flap",130,ty+16,7)
  elseif state=="play" or state=="dead" then
    draw_num(score,160,12)
  elseif state=="over" then
    -- results panel
    local px,py=100,56
    rectfill(px+2,py+2,px+121,py+97,16)      -- drop shadow
    rectfill(px,py,px+119,py+95,15)          -- card
    rect(px,py,px+119,py+95,16)
    print("GAME OVER",px+33,py+8,24)
    print("score",px+14,py+30,4)
    draw_num(score,px+34,py+42)
    print("best",px+76,py+30,4)
    draw_num(best,px+92,py+42)
    if score>=30 then sspr(24,128,22,22,px+14,py+66)
    elseif score>=10 then sspr(0,128,22,22,px+14,py+66) end
    print("\5 again",px+64,py+72,4)
  end

  if flash>0 then rectfill(0,0,319,239,7) end
end
