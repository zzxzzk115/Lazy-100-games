lazy-100 cartridge
version 1
title Breakout
author Lazy_V
__lua__
-- breakout.lz100 v2.0.0 "arcade run" - 20 layouts, 60s timed targets, multi-hit
-- bricks, falling coin/powerup drops the paddle must catch, interest on savings,
-- and a coin in-run upgrade shop (cartdata).
-- Arrows move, O launches / buys, X cashes out a met target / leaves the shop.
brows=5 bcols=13
bw=16 bh=12 bgx=56 bgy=40
BUFF_T=360          -- caught powerup duration (12s @30fps)
LVL_T=1800        -- level time limit in ticks (counts only after launch)
ICONX={w=0,s=8,b=16,l=24,m=40,c=32,t=48,e=80,g=88,v=96}
COINF={32,56,64,72} -- coin spin cycle: face, oval, edge, oval
MATC={7,12,10}      -- ball ring color per material tier
PADY=224            -- paddle row

-- 20 brick layouts: levels 1..20 in order, then random reruns. Each entry answers
-- "is there a brick at row r, col c?" (0-based).
LAYOUTS={
  function(r,c) return true end,                                   -- 1 full wall
  function(r,c) return (r+c)%2==0 end,                             -- 2 checker
  function(r,c) return r%2==0 end,                                 -- 3 row stripes
  function(r,c) return c%2==0 end,                                 -- 4 columns
  function(r,c) return c>=r and c<bcols-r end,                     -- 5 pyramid
  function(r,c) return c<=brows-1-r or c>=bcols-brows+r end,       -- 6 valley
  function(r,c) return r==0 or r==brows-1 or c==0 or c==bcols-1 end,-- 7 frame
  function(r,c) return c>=3 and c<=9 end,                          -- 8 center block
  function(r,c) return c<=2 or c>=10 end,                          -- 9 twin towers
  function(r,c) return abs(c-6)+abs(r-2)<=4 end,                   -- 10 diamond
  function(r,c) local d=abs(c-6)+abs(r-2) return d>=2 and d<=4 end,-- 11 ring
  function(r,c) return (c+r)%4<2 end,                              -- 12 zigzag
  function(r,c) return (c-r)%3~=1 end,                             -- 13 diagonals
  function(r,c) return c%4<2 end,                                  -- 14 twin columns
  function(r,c) return not (r%2==0 and c%3==2) end,                -- 15 brick wall
  function(r,c) return (c*5+r*3)%4>0 end,                          -- 16 scatter
  function(r,c) return (c>=6-r and c<=6+r) or (r>=3 and c>=5 and c<=7) end, -- 17 arrow
  function(r,c) return abs(c-3)<=r or abs(c-9)<=r end,             -- 18 twin peaks
  function(r,c) return ((c+(r%2)*2)%6)<4 end,                      -- 19 weave
  function(r,c) return ((c*13+r*7)%10)<7 end,                      -- 20 rubble
}

-- persistence: hi-score only (slot 0) - a proper roguelike, every run starts fresh
function _init()
  cartdata("breakout") -- roguelike: only the hi-score survives between runs
  hi=flr(dget(0))
  local sd=flr(dget(7)) -- rolling seed, banked at human-timed moments last session
  if sd>0 then srand(sd) end
  music(0)
  new_run()
end

function new_run()
  if tick and tick>0 then srand(tick) end -- the retry press timing reseeds the run
  up={w=0,s=0,l=0,p=0,m=0} -- run upgrades: bought in the shop, gone at run end
  level=1 score=0 lives=3+up.l tick=0 ltarget=0
  coins=0 -- run currency: every run starts broke (only upgrades and hi persist)
  mat=1+up.m -- ball material: damage per hit; caught gems raise it (cap 3)
  start_level()
end

-- the paddle's live geometry: thick raises the top edge and deepens the windows
function pad_top() return PADY-(buffs.t>0 and 4 or 0) end
function pad_h() return buffs.t>0 and 12 or 8 end

function start_level()
  state="play"
  ltick=LVL_T
  -- the target is CUMULATIVE total score: each level raises the bar further,
  -- and points spent in the shop dig into next level's progress
  ltarget=ltarget+250+(level-1)*125
  combo=0 ctimer=0 parts={} pops={} drops={}
  new_bricks()
  reset_ball()
end

function new_bricks()
  bricks={} live=0
  local pat=level<=#LAYOUTS and level or 1+flr(rnd(#LAYOUTS)) -- past 20: random reruns
  local keep=LAYOUTS[pat]
  local hc=mid(0,0.12+(level-1)*0.06,0.45)              -- stone (2-hit) chance
  local h3=level>=3 and mid(0,0.05+(level-3)*0.04,0.2) or 0 -- core (3-hit) chance
  for r=0,brows-1 do
    for c=0,bcols-1 do
      if not keep(r,c) then
        bricks[r*bcols+c]=false
      else
        local k=true
        local roll=rnd(1) -- ~1 in 4 bricks holds a powerup (it DROPS on break)
        if roll<0.025 then k="l"
        elseif roll<0.055 then k="b"
        elseif roll<0.085 then k="s"
        elseif roll<0.115 then k="w"
        elseif roll<0.145 then k="m"
        elseif roll<0.175 then k="t"
        elseif roll<0.205 then k="e"
        elseif roll<0.235 then k="g"
        elseif roll<0.26 then k="v" end
        local hp=1
        if k==true then -- only plain bricks harden
          local h=rnd(1)
          if h<h3 then hp=3 elseif h<h3+hc then hp=2 end
        end
        bricks[r*bcols+c]={k=k,hp=hp,mx=hp} live=live+1
      end
    end
  end
end

function base_pw() return 44+up.w*8 end
function pwid() return base_pw()+(buffs.w>0 and 20 or 0) end
function pspd() return 4+up.s+(buffs.s>0 and 2 or 0) end

function reset_ball()
  launched=false
  buffs={w=0,s=0,b=up.p*120,t=0,e=0,g=0} -- the power upgrade arms a power ball each serve
  local v=1+min(level-1,8)*0.06
  px=px or 140
  balls={{x=px+pwid()/2,y=200,vx=2*v,vy=-2.5*v}}
end

-- ---- particles, popups, falling drops ----
function burst(x,y,c,n)
  for i=1,n do
    parts[#parts+1]={x=x,y=y,vx=rnd(4)-2,vy=rnd(4)-2.6,l=10+flr(rnd(10)),c=c}
  end
end

function pop(x,y,t,c)
  pops[#pops+1]={x=x,y=y,t=t,c=c,l=32}
end

function drop(x,y,k)
  drops[#drops+1]={x=x,y=y,k=k,vy=1.8}
end

-- a caught drop lands its effect at the paddle
function catch_drop(k)
  if k=="c" then coins=coins+1 pop(px+pwid()/2,214,"+1",10) sfx(1)
  elseif k=="l" then lives=lives+1 pop(px+pwid()/2,214,"+1 up",11) sfx(1)
  elseif k=="w" then buffs.w=BUFF_T pop(px+pwid()/2,214,"wide!",12) sfx(1)
  elseif k=="s" then buffs.s=BUFF_T pop(px+pwid()/2,214,"speed!",10) sfx(1)
  elseif k=="b" then buffs.b=BUFF_T pop(px+pwid()/2,214,"power!",9) sfx(1)
  elseif k=="m" then
    if mat<3 then mat=mat+1 pop(px+pwid()/2,214,"ball up!",MATC[mat])
    else coins=coins+3 pop(px+pwid()/2,214,"+3",10) end
    sfx(1)
  elseif k=="v" then
    -- split: the lead ball forks into two extra balls (5 on screen max)
    if launched and #balls>0 and #balls<5 then
      local src=balls[1]
      for s=-1,1,2 do
        if #balls<5 then
          balls[#balls+1]={x=src.x,y=src.y,vx=mid(-4,src.vx+s*1.2,4),vy=src.vy}
        end
      end
      pop(px+pwid()/2,214,"split!",14)
    else coins=coins+3 pop(px+pwid()/2,214,"+3",10) end
    sfx(1)
  elseif k=="t" then buffs.t=BUFF_T pop(px+pwid()/2,214,"thick!",7) sfx(1)
  elseif k=="e" then buffs.e=BUFF_T pop(px+pwid()/2,214,"bouncy!",11) sfx(1)
  elseif k=="g" then buffs.g=BUFF_T pop(px+pwid()/2,214,"magnet!",8) sfx(1)
  end
end

-- one ball contact: material deals damage; the brick breaks at 0 hp.
function hit_brick(i,r,c)
  local x0=bgx+c*bw local y0=bgy+r*bh
  local b=bricks[i]
  local dmg=buffs.b>0 and 99 or mat
  b.hp=b.hp-dmg
  if b.hp>0 then -- chipped, not broken
    score=score+5
    if ctimer>0 then ctimer=45 end
    burst(x0+bw/2,y0+bh/2,6,4)
    sfx(0)
    return false
  end
  bricks[i]=false live=live-1
  if ctimer>0 then combo=combo+1 else combo=1 end
  ctimer=45
  local pts=10*b.mx*combo -- harder bricks pay out more score
  score=score+pts
  if score>hi then hi=score dset(0,hi) end
  burst(x0+bw/2,y0+bh/2,b.mx>1 and 6 or 8+r,10)
  if combo>=2 then pop(x0+bw/2,y0,"combo x"..combo,8+(combo%8)) end
  -- loot falls and must be caught: powerup bricks drop their pickup, plain ones
  -- drop a coin by tier chance (stone often, core always)
  if b.k~=true then
    drop(x0+bw/2,y0,b.k)
  else
    local cc=b.mx==3 and 1 or (b.mx==2 and 0.5 or 0.22)
    if rnd(1)<cc then drop(x0+bw/2,y0,"c") end
  end
  sfx(2)
  return true
end

-- ---- the shop (between levels): permanent upgrades priced in coins ----
SHOP={
  {k="w",name="wide paddle", max=3,base=15},
  {k="s",name="fast paddle", max=3,base=12},
  {k="l",name="extra life",  max=2,base=30},
  {k="p",name="power serve", max=3,base=20},
  {k="m",name="ball material",max=2,base=40},
  {k="x",name="100 pts > 2",max=0,base=0}, -- repeatable: sells target progress for coins
}
function shop_cost(it) local o=up[it.k] return it.base*(2^o) end

function enter_shop(bonus)
  state="shop" ssel=1 oheld=true -- swallow any O still held from play
  sbonus=bonus
  -- interest on savings: +1 coin per 10 held, capped at +10 (100+ banked)
  sint=flr(min(flr(coins/10),10)) -- flr: the min binding returns a float
  coins=coins+sint
  xleft=3 -- the point exchange is rationed per shop visit
end

function update_shop()
  if btnp(2) then ssel=(ssel-2)%#SHOP+1 sfx(0) end
  if btnp(3) then ssel=ssel%#SHOP+1 sfx(0) end
  -- buy on a CLEAN O press only: btnp auto-repeats after ~0.5s, which would
  -- machine-gun purchases while the button is held
  local o=btn(4)
  if o and not oheld then
    local it=SHOP[ssel]
    if it.k=="x" then -- greed: 100 points -> 2 coins, max 3 times per visit
      if xleft>0 and score>=100 then score=score-100 coins=coins+2 xleft=xleft-1 sfx(1) else sfx(3) end
    else
    local cost=shop_cost(it)
    if up[it.k]<it.max and coins>=cost then
      coins=coins-cost up[it.k]=up[it.k]+1
      if it.k=="m" then mat=max(mat,1+up.m) end
      if it.k=="l" then lives=lives+1 end -- lives apply on the spot
      sfx(1)
    else sfx(3) end
    end
  end
  oheld=o
  if btnp(5) then
    level=level+1 px=nil
    start_level()
  end
end

function _update()
  tick=tick+1
  if state=="shop" then update_shop() return end
  if state=="over" then
    if btnp(4) then new_run() end
    return
  end

  -- the clock only runs once the ball is live; time-up judges the target
  if launched then
    ltick=ltick-1
    if ltick<=0 then
      if score>=ltarget then level_clear() else game_over("time") end
      return
    end
  end

  if ctimer>0 then ctimer=ctimer-1 else combo=0 end
  for k,v in pairs(buffs) do if v>0 then buffs[k]=v-1 end end

  if btn(0) then px=px-pspd() end
  if btn(1) then px=px+pspd() end
  px=mid(0,px,320-pwid())

  if not launched then
    balls[1].x=px+pwid()/2 balls[1].y=200
    if btnp(4) then launched=true end
  else
    for bi=#balls,1,-1 do
      local B=balls[bi]
      B.x=B.x+B.vx B.y=B.y+B.vy
      if buffs.b>0 then burst(B.x,B.y,9,1) end
      if mat==3 then burst(B.x,B.y,10,1) end

      if B.x<4 then B.x=4 B.vx=-B.vx sfx(0) burst(4,B.y,7,4) end
      if B.x>316 then B.x=316 B.vx=-B.vx sfx(0) burst(316,B.y,7,4) end
      if B.y<12 then B.y=12 B.vy=-B.vy sfx(0) burst(B.x,12,7,4) end

      -- paddle bounce: thick deepens the window, elastic adds pace and control
      local ptop=pad_top()
      if B.vy>0 and B.y>ptop-8 and B.y<ptop+pad_h()-2 and B.x>px-4 and B.x<px+pwid() then
        B.y=ptop-8
        local m=abs(B.vy)
        if buffs.e>0 then m=mid(3,m*1.25,6) end
        B.vy=-m
        B.vx=mid(-4, B.vx+(B.x-(px+pwid()/2))/(buffs.e>0 and 8 or 10), 4)
        sfx(1) burst(B.x,ptop+2,buffs.e>0 and 11 or 12,6)
      end

      local hitb=false
      for r=0,brows-1 do
        for c=0,bcols-1 do
          local i=r*bcols+c
          if bricks[i] and (buffs.b>0 or not hitb) then
            local x0=bgx+c*bw local y0=bgy+r*bh
            if B.x>x0-2 and B.x<x0+bw and B.y>y0-2 and B.y<y0+bh-1 then
              local broke=hit_brick(i,r,c)
              hitb=true
              if not (broke and buffs.b>0) then B.vy=-B.vy end
            end
          end
        end
      end

      if B.y>244 then table.remove(balls,bi) end
    end
    if #balls==0 then -- only when EVERY ball is gone does it cost a life
      lives=lives-1 sfx(3)
      if lives<=0 then game_over("dead") return else reset_ball() end
    end
  end

  -- once the target is banked, X cashes out early (leftover time pays out)
  if score>=ltarget and btnp(5) then level_clear() return end
  if live<=0 then new_bricks() end

  -- falling drops: the paddle catches them, past the bottom they are lost.
  -- an active magnet steers coins toward the paddle center.
  local ptop2=pad_top()
  for i=#drops,1,-1 do
    local d=drops[i]
    d.y=d.y+d.vy
    if buffs.g>0 then -- the magnet pulls EVERY drop toward the paddle center
      local cx=px+pwid()/2
      d.x=d.x+mid(-2.4,(cx-d.x)/8,2.4)
      if tick%3==0 then burst(d.x,d.y,d.k=="c" and 10 or 12,1) end -- attracted drops spark
    end
    if d.y>=ptop2-6 and d.y<=ptop2+pad_h()+4 and d.x>=px-4 and d.x<=px+pwid()+4 then
      catch_drop(d.k)
      table.remove(drops,i)
    elseif d.y>240 then
      table.remove(drops,i)
    end
  end

  for i=#parts,1,-1 do
    local p=parts[i]
    p.x=p.x+p.vx p.y=p.y+p.vy p.vy=p.vy+0.15 p.l=p.l-1
    if p.l<=0 then table.remove(parts,i) end
  end
  for i=#pops,1,-1 do
    local p=pops[i]
    p.y=p.y-0.6 p.l=p.l-1
    if p.l<=0 then table.remove(pops,i) end
  end
end

function level_clear()
  dset(7,tick%30000+1) -- bank entropy for the next session's opening wall
  local secs=flr(ltick/30)
  local bonus=secs*8
  score=score+bonus
  if score>hi then hi=score dset(0,hi) end
  enter_shop(bonus)
end

function game_over(why)
  dset(7,tick%30000+1) -- bank entropy for the next session's opening wall
  state="over" over_why=why or "dead"
  if score>hi then hi=score dset(0,hi) end
end

function draw_hud()
  -- row 1: lv / score / hi / lives / seconds
  print("lv "..level,6,2,7)
  print("score "..score,44,2,7)
  print("hi "..hi,146,2,10)
  print("lives "..lives,250,2,7)
  local sec=flr(ltick/30)
  print(sec,306,2,(launched and sec<10) and 8 or 7)
  -- row 2: combo (left) + target progress bar (right, clear of the lives text)
  if combo>=2 then print("combo x"..combo,6,12,8+(tick/4)%8) end
  local tw=flr(mid(0,score/ltarget,1)*80)
  rectfill(200,13,200+tw,16,11) rect(199,12,281,17,5)
  if score>=ltarget and tick%20<12 then print(" shop",248,20,11) end -- under the bar, inside the screen
  -- countdown strip above the paddle lane
  local rw=flr(ltick/LVL_T*312)
  rectfill(4,234,4+rw,236,(launched and sec<10) and 8 or 3)
  -- bottom-left: coin purse, material gauge, active buffs
  sspr(32,16,8,8,6,220) print(coins,17,220,10)
  sspr(40,16,8,8,44,220)
  for m=1,3 do print(m<=mat and "|" or ".",54+m*4,220,m<=mat and MATC[mat] or 5) end
  local bxp=84
  for _,k in ipairs({"w","t","e","g","s","b"}) do
    if buffs[k]>0 then
      sspr(ICONX[k],16,8,8,bxp,220)
      rectfill(bxp,229,bxp+flr(buffs[k]/BUFF_T*8),230,11)
      bxp=bxp+12
    end
  end
end

function draw_shop()
  rectfill(52,42,268,204,1) rect(52,42,268,204,7) rect(54,44,266,202,13)
  print("LEVEL "..level.." CLEAR!",116,50,11)
  print("time bonus +"..sbonus,116,62,10)
  sspr(32,16,8,8,116,76) print("x "..flr(coins),128,76,10)
  print("int +"..sint,176,76,sint>0 and 11 or 5)
  print("pts "..flr(score),224,76,7)
  for i,it in ipairs(SHOP) do
    local y=92+(i-1)*16
    local own=up[it.k]
    if i==ssel then rectfill(58,y-2,262,y+10,2) print(">",62,y,10) end
    sspr(it.k=="x" and 32 or ICONX[it.k],16,8,8,72,y)
    print(it.name,86,y,i==ssel and 7 or 6)
    if it.k=="x" then
      if xleft>0 then
        print("-100 pts x"..xleft,196,y,score>=100 and 10 or 8)
      else
        print("out",212,y,5)
      end
    else
    for m=1,it.max do
      print(m<=own and "|" or ".",182+m*6,y,m<=own and 11 or 5)
    end
    if own<it.max then
      sspr(32,16,8,8,212,y) print(shop_cost(it),224,y,coins>=shop_cost(it) and 10 or 8)
    else
      print("max",212,y,11)
    end
    end
  end
  print(" buy    next level",96,186,7)
end

function draw_brick(b,x0,y0,r)
  if b.mx==2 then pal(8,6) elseif b.mx==3 then pal(8,5) else pal(8,8+r) end
  spr(1,x0,y0)
  pal()
  if b.k~=true then
    sspr(ICONX[b.k],16,8,8, x0+4, y0+2)
  end
  if b.hp<b.mx then -- cracks deepen as hp drops
    line(x0+4,y0+2,x0+9,y0+8,0)
    line(x0+9,y0+8,x0+6,y0+10,0)
    if b.hp<=1 and b.mx==3 then
      line(x0+11,y0+3,x0+8,y0+7,0)
      line(x0+3,y0+9,x0+6,y0+5,0)
    end
  end
end

function _draw()
  cls(0)
  -- living starfield: the star map drifts slowly (drawn twice for the wrap) and a
  -- handful of hashed stars twinkle on top
  local sox=flr(tick/6)%320
  map(0,0,-sox,0,20,15)
  map(0,0,320-sox,0,20,15)
  for i=0,13 do
    local sx=(i*89+37)%316+2
    local sy=(i*53+11)%230+4
    local tw=(flr(tick/8)+i)%4
    if tw<3 then pset(sx,sy,tw==0 and 7 or (tw==1 and 6 or 5)) end
  end
  for r=0,brows-1 do
    for c=0,bcols-1 do
      local b=bricks[r*bcols+c]
      if b then draw_brick(b,bgx+c*bw,bgy+r*bh,r) end
    end
  end
  sspr(48,0,16,6, px or 140,pad_top(), pwid(),pad_h())
  if state~="shop" then
    for _,B in ipairs(balls) do
      spr(2, B.x-8, B.y-8)
      if mat>1 then circ(B.x,B.y,6,MATC[mat]) end
    end
  end
  for _,d in ipairs(drops) do
    if d.k=="c" then -- coins tumble through the classic 4-frame spin
      sspr(COINF[1+flr(tick/4)%4],16,8,8,d.x-4,d.y-4)
    else
      sspr(ICONX[d.k],16,8,8,d.x-4,d.y-4)
    end
  end
  for _,p in ipairs(parts) do rectfill(p.x,p.y,p.x+1,p.y+1,p.c) end
  for _,p in ipairs(pops) do
    print(p.t, p.x-#p.t*2, p.y, p.l<8 and 5 or p.c)
  end
  draw_hud()

  if state=="play" and not launched then
    print("target "..ltarget.."  go!",112,140,10)
    print(" launch    move",96,152,7)
  elseif state=="shop" then
    draw_shop()
  elseif state=="over" then
    rectfill(84,84,236,156,1) rect(84,84,236,156,7)
    print(over_why=="time" and "TIME UP!" or "GAME OVER",128,94,8)
    print("score "..score,116,112,7)
    print("hi "..hi,116,124,10)
    sspr(32,16,8,8,180,112) print("x "..coins,192,112,10)
    print(" try again",124,142,7)
  end
end
__gfx__
































































































































































































































































__map__
0809080908090809080908090809080908090809ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
