lazy-100 cartridge
version 1
title Snake
author MickeyMiao
__lua__
-- Snake Game
-- Controls: D-pad to move, X to restart

function _init()
    restart()
end

function restart()
    snake = {}
    table.insert(snake, {x = 10, y = 7})
    table.insert(snake, {x = 9, y = 7})
    table.insert(snake, {x = 8, y = 7})
    dir = 0
    next_dir = 0
    food = {x = 15, y = 7}
    score = 0
    game_over = false
    timer = 0
    speed = 0.2
end

function _update()
    if game_over then
        if btnp(5) then restart() end
        return
    end
    -- btn: 0=left, 1=right, 2=up, 3=down
    -- dir: 0=right, 1=down, 2=left, 3=up
    if btnp(0) and dir ~= 0 then next_dir = 2 end  -- left -> go left (not if going right)
    if btnp(1) and dir ~= 2 then next_dir = 0 end  -- right -> go right (not if going left)
    if btnp(2) and dir ~= 1 then next_dir = 3 end  -- up -> go up (not if going down)
    if btnp(3) and dir ~= 3 then next_dir = 1 end  -- down -> go down (not if going up)
    timer = timer + 1/30
    if timer >= speed then
        timer = 0
        dir = next_dir
        move_snake()
    end
end

function move_snake()
    local head = snake[1]
    local new_x, new_y = head.x, head.y
    if dir == 0 then new_x = new_x + 1 end
    if dir == 1 then new_y = new_y + 1 end
    if dir == 2 then new_x = new_x - 1 end
    if dir == 3 then new_y = new_y - 1 end
    if new_x < 0 or new_x >= 20 or new_y < 0 or new_y >= 15 then
        game_over = true
        return
    end
    for i, seg in ipairs(snake) do
        if seg.x == new_x and seg.y == new_y then
            game_over = true
            return
        end
    end
    table.insert(snake, 1, {x = new_x, y = new_y})
    if new_x == food.x and new_y == food.y then
        score = score + 10
        speed = max(0.05, speed - 0.005)
        spawn_food()
    else
        table.remove(snake)
    end
end

function spawn_food()
    local valid = false
    while not valid do
        food.x = flr(rnd(20))
        food.y = flr(rnd(15))
        valid = true
        for i, seg in ipairs(snake) do
            if seg.x == food.x and seg.y == food.y then
                valid = false
                break
            end
        end
    end
end

function _draw()
    cls(0)
    rect(0, 0, 319, 239, 7)
    for y = 0, 14 do
        for x = 0, 19 do
            local px = x * 16
            local py = y * 16 + 4
            rectfill(px, py, px + 15, py + 15, 1)
            rect(px, py, px + 15, py + 15, 2)
        end
    end
    for i, seg in ipairs(snake) do
        local px = seg.x * 16
        local py = seg.y * 16 + 4
        local col = 11
        if i == 1 then col = 10 end
        rectfill(px + 1, py + 1, px + 14, py + 14, col)
    end
    local fx = food.x * 16
    local fy = food.y * 16 + 4
    circfill(fx + 8, fy + 8, 6, 8)
    rectfill(fx + 6, fy + 2, fx + 10, fy + 5, 3)
    print("score: " .. score, 8, 4, 7)
    if game_over then
        rectfill(60, 80, 260, 160, 0)
        rect(60, 80, 260, 160, 8)
        print("game over!", 120, 95, 8)
        print("score: " .. score, 130, 115, 7)
        print("press \6 to restart", 100, 140, 7)
    end
end

