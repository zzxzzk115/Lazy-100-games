{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/zzxzzk115/Lazy-100-games/main/schema/games.schema.json",
  "title": "LAZY-100 games catalog",
  "type": "object",
  "required": ["schemaVersion", "kind", "games"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "kind": { "type": "string", "const": "lazy100.gamesCatalog" },
    "name": { "type": "string" },
    "repository": { "type": "string", "format": "uri" },
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "author", "version", "category", "cart"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,31}$",
            "description": "Stable unique identifier; also the cart's local filename stem."
          },
          "name": { "type": "string", "minLength": 1 },
          "author": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Semantic version of the cart."
          },
          "category": {
            "type": "string",
            "enum": ["arcade", "action", "puzzle", "platformer", "shooter", "rpg", "racing", "sports", "strategy", "demo", "tool", "other"]
          },
          "tags": { "type": "array", "items": { "type": "string" } },
          "license": { "type": "string", "description": "SPDX license id of the game itself." },
          "repository": { "type": "string", "description": "The game's own source repository, if any. May be empty." },
          "featured": { "type": "boolean", "description": "Show on the site's home page." },
          "cart": {
            "type": "string",
            "pattern": "^games/[a-z0-9][a-z0-9_-]*/[a-z0-9][a-z0-9_-]*\\.lz100\\.png$",
            "description": "Repo-relative path to the PNG cartridge (.lz100.png): a playable cart whose visible cover doubles as the preview image. Required."
          },
          "source": {
            "type": "string",
            "pattern": "^games/[a-z0-9][a-z0-9_-]*/[a-z0-9][a-z0-9_-]*\\.lz100$",
            "description": "Optional repo-relative path to the plain-text .lz100 cart, provided for human code review."
          },
          "preview": {
            "type": "string",
            "pattern": "^games/[a-z0-9][a-z0-9_-]*/[a-z0-9][a-z0-9_-]*\\.png$",
            "description": "Optional distinct preview PNG. Omit to use the cart's own cover image."
          }
        },
        "additionalProperties": false
      }
    }
  }
}
